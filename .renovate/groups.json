{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "description": "Flux Operator Group",
      "groupName": "flux-operator",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/controlplaneio-fluxcd/charts/flux-operator",
        "ghcr.io/controlplaneio-fluxcd/charts/flux-instance"
      ],
      "minimumGroupSize": 2
    },
    {
      "description": "Node Exporter Group",
      "groupName": "node-exporter",
      "matchDatasources": ["docker", "github-releases"],
      "matchPackageNames": ["quay.io/prometheus/node-exporter", "prometheus/node_exporter"],
      "minimumGroupSize": 2
    },
    {
      "description": "Rook Ceph Group",
      "groupName": "rook-ceph",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/rook/rook-ceph", "ghcr.io/rook/rook-ceph-cluster"],
      "minimumGroupSize": 2
    }
  ]
}
